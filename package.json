{
  "name": "nexa",
  "version": "0.1.0",
  "private": true,
  "description": "Nexa event vendor access marketplace. Powered by ERA.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --linked --schema public > src/lib/db/generated.ts",
    "e2e:messaging": "tsx --tsconfig scripts/tsconfig.e2e.json --env-file=.env.local scripts/e2e-messaging.ts",
    "e2e:marketplace": "tsx --tsconfig scripts/tsconfig.e2e.json --env-file=.env.local scripts/e2e-marketplace.ts",
    "e2e:studio": "tsx --tsconfig scripts/tsconfig.e2e.json --env-file=.env.local scripts/e2e-studio.ts",
    "e2e:admin": "tsx --tsconfig scripts/tsconfig.e2e.json --env-file=.env.local scripts/e2e-admin.ts",
    "e2e:staff": "tsx --tsconfig scripts/tsconfig.e2e.json --env-file=.env.local scripts/e2e-staff.ts",
    "seed:demo": "tsx --tsconfig scripts/tsconfig.e2e.json --env-file=.env.local scripts/seed-demo.ts",
    "e2e:purge": "tsx --tsconfig scripts/tsconfig.e2e.json --env-file=.env.local scripts/e2e-purge.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.58.0",
    "clsx": "^2.1.1",
    "next": "^15.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "^0.0.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.5.4",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.23.0",
    "typescript": "^5.9.2"
  }
}

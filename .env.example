# Supabase — from your project's API settings.
# NEXT_PUBLIC_* values are exposed to the browser and are safe to expose (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. Never import this into a client component.
SUPABASE_SERVICE_ROLE_KEY=

# Payments. "mock" until Flutterwave's escrow product is confirmed for the account (PRD Section 20, Still Open).
PAYMENT_GATEWAY=mock
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase - from your project's API settings.
# NEXT_PUBLIC_* values are exposed to the browser and are safe to expose because RLS protects the data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. Never import this into a client component.
SUPABASE_SERVICE_ROLE_KEY=

# Fixed Nexa Admin login.
# Admin types NEXA_SUPER_ADMIN_USERNAME on the Admin login screen.
# NEXA_SUPER_ADMIN_EMAIL is the hidden Supabase Auth account used behind the scenes.
# Change the Admin password by changing NEXA_SUPER_ADMIN_PASSWORD in Railway and redeploying.
NEXA_SUPER_ADMIN_USERNAME=admin
NEXA_SUPER_ADMIN_EMAIL=admin@nexa.local
NEXA_SUPER_ADMIN_PASSWORD=

# Payments - Flutterwave.
# Nexa IS the escrow: customers pay into Nexa's Flutterwave balance via hosted
# checkout, and vendors are paid out by Transfer once the customer confirms with
# their code. "mock" is a fake gateway for local development - no real money moves.
PAYMENT_GATEWAY=mock
FLUTTERWAVE_SECRET_KEY=
# The "Secret Hash" set in the Flutterwave dashboard under Settings -> Webhooks.
FLUTTERWAVE_WEBHOOK_SECRET=

# Transactional email - Resend. Signup codes, vendor invites, staff invites,
# password resets. Without these, nobody can be onboarded or reset a password.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# WhatsApp Business Platform. Customers and vendors both message Nexa's number and
# Nexa relays between them - neither side ever sees the other's number.
NEXT_PUBLIC_WHATSAPP_NUMBER=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# The approved Meta template Nexa falls back to when someone has not messaged in
# over 24 hours and WhatsApp will no longer accept free text from a business.
WHATSAPP_TEMPLATE_NAME=nexa_new_message
WHATSAPP_TEMPLATE_LANG=en

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# The live customer apex. Leave UNSET in development and on the raw Railway URL -
# the app stays single-domain (every surface reachable by path). Set it only once
# the custom domain is live, and each surface moves to its own subdomain:
#   nexa.erasystems.com.ng | vendor. | admin.
# NEXT_PUBLIC_ROOT_DOMAIN=nexa.erasystems.com.ng

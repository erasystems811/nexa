# Supabase â€” from your project's API settings.
# NEXT_PUBLIC_* values are exposed to the browser and are safe to expose (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. Never import this into a client component.
SUPABASE_SERVICE_ROLE_KEY=

# Payments. "mock" until Flutterwave's escrow product is confirmed for the account (PRD Section 20, Still Open).
PAYMENT_GATEWAY=mock
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=


NEXT_PUBLIC_SITE_URL=http://localhost:3000

# The live customer apex. Leave UNSET in development and on the raw Railway URL â€”
# the app stays single-domain (every surface reachable by path). Set it only
# once the custom domain is live, and each surface moves to its own subdomain:
#   nexa.erasystems.com.ng (customer) Â· vendor. Â· rider. Â· admin.
# NEXT_PUBLIC_ROOT_DOMAIN=nexa.erasystems.com.ng
